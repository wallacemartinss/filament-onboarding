{
    "name": "wallacemartinss/filament-onboarding",
    "description": "Database-driven onboarding for Filament: progress checklists and guided spotlight tours, translatable to any locale.",
    "keywords": [
        "laravel",
        "filament",
        "onboarding",
        "product-tour",
        "checklist",
        "walkthrough",
        "filament-plugin"
    ],
    "homepage": "https://github.com/wallacemartinss/filament-onboarding",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Wallace Martins",
            "email": "wallacemartinss@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.26",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0",
        "wallacemartinss/filament-icon-picker": "^2.0"
    },
    "suggest": {
        "wallacemartinss/filament-icon-picker": "Turns the icon field of flows and steps into a visual picker over every installed icon set (^2.0)."
    },
    "autoload": {
        "psr-4": {
            "Wallacemartinss\\FilamentOnboarding\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wallacemartinss\\FilamentOnboarding\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wallacemartinss\\FilamentOnboarding\\FilamentOnboardingServiceProvider"
            ],
            "aliases": {
                "Onboarding": "Wallacemartinss\\FilamentOnboarding\\Facades\\Onboarding"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
