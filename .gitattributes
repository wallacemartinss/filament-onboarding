* text=auto eol=lf

*.blade.php diff=html
*.css       diff=css
*.js        diff=javascript
*.md        diff=markdown
*.php       diff=php

# Kept out of the Composer archive. Nothing here is needed at runtime, and the
# screenshots alone are megabytes — they belong in the repository, not in every
# vendor/ directory that installs this package.
/.github         export-ignore
/bin             export-ignore
/docs            export-ignore
/tests           export-ignore
.gitattributes   export-ignore
.gitignore       export-ignore
phpunit.xml      export-ignore
pint.json        export-ignore
vitest.config.js export-ignore
